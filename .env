# Ollama Configuration
# Địa chỉ Ollama (localhost hoặc ngrok URL)
OLLAMA_HOST=http://localhost:11434
# Nếu dùng ngrok thì uncomment dòng dưới
# OLLAMA_HOST=https://chery-unnatural-collinearly.ngrok-free.dev

# Model Ollama dùng cho dịch thuật
#OLLAMA_MODEL=llama3.2
OLLAMA_MODEL=spTranl

# Hotkey Configuration
# enabled: true/false
HOTKEY_ENABLED=true
# Format: {modifier}+{char}
# Modifier: 1=Control, 16=Alt, 32=Shift, 64=Meta, 256=Control (cũ)
# Char: ASCII value (T=84, A=65, Ctrl=256 trong old format)
HOTKEY_CONFIG=256+160
HOTKEY_DESCRIPTION=Ctrl+Alt+T

# Timeout cho API calls (giây)
OLLAMA_TIMEOUT=120
